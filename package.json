{
  "name": "natours",
  "version": "1.0.0",
  "description": "Learning Node, Express and MongoDB",
  "license": "ISC",
  "author": "Cornelius Ndirangu",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development node starter/server.js",
    "dev": "cross-env NODE_ENV=development nodemon starter/server.js",
    "start:prod": "cross-env NODE_ENV=production node starter/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "debug": "node --inspect starter/server.js",
    "debug-brk": "node --inspect-brk starter/server.js",
    "watch:js": "parcel watch starter/public/js/index.js --out-dir starter/public/dist/js --out-file bundle.js",
    "build:js": "parcel build starter/public/js/index.js --out-dir starter/public/dist/js --out-file bundle.js"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "parcel-bundler": "^1.12.5",
    "postman-to-openapi": "^1.2.0",
    "pug": "^3.0.3",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.26",
    "xss-clean": "^0.1.4",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^5.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^2.7.0",
    "globals": "^17.1.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
